# ── MongoDB ──────────────────────────────────────────
# Set to "true" to use an in-memory mock DB (no MongoDB needed)
# Set to "false" to connect to a real MongoDB instance
USE_MOCK_DB=true

# Only needed when USE_MOCK_DB=false
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
MONGODB_URL=mongodb://localhost:27017

# ── Groq ───────────────────────────────────────────
# Set your API key for AI-generated study plans
# Leave as-is for a locally-generated fallback plan
# GROQ_API_KEY=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
# GOOGLE_API_KEY=AIzaSyAPne_dQf8qwxo4GcjpbPZ0M5nSOVPr7_4
OPENAI_API_KEY=your_openai_api_key_here
